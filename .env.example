# ─────────────────────────────────────────────────────────────
# DLS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase / PostgreSQL Database ──────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format (Session mode for serverless).
DATABASE_URL=postgresql://postgres:[YOUR-SUPABASE-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Firebase Admin SDK ───────────────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" — download the JSON file
# 3. Set the PATH to that file here (absolute path), OR
#    paste the JSON content as a single-line string in FIREBASE_SERVICE_ACCOUNT_JSON below.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── API Security ─────────────────────────────────────────────
# A secret key used to protect the payment callback webhook.
# Your payment gateway should send this in the X-Webhook-Secret header.
WEBHOOK_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# ── Payment Portal ───────────────────────────────────────────
# The URL sent to devices when their payment is overdue.
PAYMENT_PORTAL_URL=https://pay.yourbusiness.com/checkout
